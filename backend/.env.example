# Bingwa AI — Environment Variables
# Copy this to .env and fill in values. Never commit .env

# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
# Port 5433 avoids conflict with any local PostgreSQL installation (Docker maps 5433→5432 in container)
DATABASE_URL=postgresql://bingwa:localonly@localhost:5433/bingwa_ai

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
NLP_MODEL=claude-sonnet-4-5
NLP_MAX_TOKENS=500

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=bingwa-webhook-verify-2026
WHATSAPP_BUSINESS_ACCOUNT_ID=

# MTN Mobile Money Uganda
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox  # sandbox | production

# Airtel Money Uganda
AIRTEL_MONEY_BASE_URL=https://openapi.airtel.africa
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=

# Logging
LOG_LEVEL=debug  # debug | info | warn | error

# Scheduled jobs timezone
TZ=Africa/Kampala
