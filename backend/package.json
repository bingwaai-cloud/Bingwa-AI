{
  "name": "bingwa-ai-backend",
  "version": "0.1.0",
  "description": "Bingwa AI — WhatsApp ERP for East African businesses",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "postinstall": "prisma generate --schema=db/schema.prisma",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:nlp": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/nlp --verbose --forceExit",
    "test:api": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/api --verbose",
    "test:reports": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/reports --verbose --forceExit",
    "migrate": "prisma migrate dev --schema=db/schema.prisma",
    "migrate:prod": "prisma migrate deploy --schema=db/schema.prisma",
    "typecheck": "tsc --noEmit",
    "lint": "node node_modules/eslint/bin/eslint.js src --ext .ts",
    "studio": "prisma studio --schema=db/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@prisma/client": "^5.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^3.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.0.0",
    "prisma": "^5.0.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
